datasource db {
  provider = "sqlite"
  url      = "file:../dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String
  role         String      // ADMIN, SAFETY_OFFICER, CONTROL_ROOM_OPERATOR, PLANT_MANAGER
  createdAt    DateTime    @default(now())
  auditLogs    AuditLog[]
}

model Plant {
  id        String   @id @default(uuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  zones     Zone[]
}

model Zone {
  id                   String                 @id @default(uuid())
  name                 String
  code                 String                 @unique
  plantId              String
  plant                Plant                  @relation(fields: [plantId], references: [id], onDelete: Cascade)
  coordinates          String                 // SVG polygon coordinate points e.g. "100,100 200,100 200,200 100,200"
  riskScore            Float                  @default(0.0)
  riskSeverity         String                 @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  updatedAt            DateTime               @updatedAt
  equipment            Equipment[]
  sensors              Sensor[]
  workers              Worker[]
  workerLocationEvents WorkerLocationEvent[]
  shiftLogs            ShiftLog[]
  permits              Permit[]
  riskEvents           RiskEvent[]
  alerts               Alert[]
  incidents            Incident[]
  nearMisses           NearMiss[]
}

model Equipment {
  id                 String              @id @default(uuid())
  name               String
  code               String              @unique
  type               String
  zoneId             String
  zone               Zone                @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  healthScore        Float               @default(100.0)
  status             String              @default("OPERATIONAL") // OPERATIONAL, DEGRADED, MAINTENANCE, OFFLINE
  lastMaintenance    DateTime?
  nextMaintenance    DateTime?
  sensors            Sensor[]
  permits            Permit[]
  maintenanceRecords MaintenanceRecord[]
}

model Sensor {
  id                String          @id @default(uuid())
  name              String
  code              String          @unique
  type              String          // combustible_gas, toxic_gas, oxygen, temperature, pressure, vibration, ventilation
  unit              String
  equipmentId       String?
  equipment         Equipment?      @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  zoneId            String
  zone              Zone            @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  minValue          Float           @default(0.0)
  maxValue          Float
  thresholdWarning  Float
  thresholdCritical Float
  lastReading       Float?
  lastReadingTime   DateTime?
  status            String          @default("NORMAL") // NORMAL, WARNING, CRITICAL, FAULT
  readings          SensorReading[]
  alerts            Alert[]
}

model SensorReading {
  id        String   @id @default(uuid())
  sensorId  String
  sensor    Sensor   @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  value     Float
  timestamp DateTime @default(now())

  @@index([sensorId, timestamp])
}

model Worker {
  id                   String                @id @default(uuid())
  name                 String
  badgeNumber          String                @unique
  role                 String
  status               String                @default("OFF_DUTY") // ON_DUTY, OFF_DUTY, HAZARD_EXPOSURE, EVACUATED
  currentZoneId        String?
  currentZone          Zone?                 @relation(fields: [currentZoneId], references: [id], onDelete: SetNull)
  checkInTime          DateTime?
  workerLocationEvents WorkerLocationEvent[]
  permits              PermitWorker[]
  permitsLead          Permit[]
  maintenanceRecords   MaintenanceRecord[]
}

model WorkerLocationEvent {
  id        String   @id @default(uuid())
  workerId  String
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  zoneId    String
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())
  eventType String   // ENTRY, EXIT, ALARM
}

model Shift {
  id        String     @id @default(uuid())
  code      String     @unique
  name      String
  startTime String     // e.g. "08:00"
  endTime   String     // e.g. "16:00"
  shiftLogs ShiftLog[]
}

model ShiftLog {
  id               String   @id @default(uuid())
  shiftId          String
  shift            Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  zoneId           String
  zone             Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  supervisorId     String
  logText          String
  handoverQuality  String   @default("GOOD") // GOOD, FAIR, POOR
  timestamp        DateTime @default(now())
}

model Permit {
  id             String          @id @default(uuid())
  permitNumber   String          @unique
  type           String          // HOT_WORK, CONFINED_SPACE, ELECTRICAL_ISOLATION, HEIGHTS, EXCAVATION
  zoneId         String
  zone           Zone            @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  equipmentId    String?
  equipment      Equipment?      @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  workerId       String          // Lead Worker / Supervisor
  leadWorker     Worker          @relation(fields: [workerId], references: [id], onDelete: Cascade)
  status         String          @default("REQUESTED") // REQUESTED, APPROVED, ACTIVE, ON_HOLD, SUSPENDED, COMPLETED
  startTime      DateTime
  endTime        DateTime
  hazards        String          // Comma-separated list of hazards
  controls       String          // Comma-separated list of safety controls
  permitWorkers  PermitWorker[]
}

model PermitWorker {
  id       String @id @default(uuid())
  permitId String
  permit   Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)
  workerId String
  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([permitId, workerId])
}

model MaintenanceRecord {
  id            String    @id @default(uuid())
  equipmentId   String
  equipment     Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  workerId      String
  technician    Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  type          String    // PREVENTIVE, CORRECTIVE, EMERGENCY
  description   String
  status        String    @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, OVERDUE
  scheduledDate DateTime
  completedDate DateTime?
  cost          Float     @default(0.0)
}

model RiskEvent {
  id                String             @id @default(uuid())
  zoneId            String
  zone              Zone               @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  severity          String             @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  score             Float              @default(0.0)
  predictedIncident String
  confidence        Float
  leadTime          Float              @default(0.0) // Warning lead time in seconds
  status            String             @default("ACTIVE") // ACTIVE, MITIGATED, FALSE_POSITIVE
  detectedTime      DateTime           @default(now())
  closedTime        DateTime?
  factors           RiskEventFactor[]
  evidence          RiskEventEvidence[]
  interventions     Intervention[]
}

model RiskEventFactor {
  id          String    @id @default(uuid())
  riskEventId String
  riskEvent   RiskEvent @relation(fields: [riskEventId], references: [id], onDelete: Cascade)
  factorName  String
  weight      Float     // Numeric weight contribution e.g. 0.45 (meaning 45%)
}

model RiskEventEvidence {
  id          String    @id @default(uuid())
  riskEventId String
  riskEvent   RiskEvent @relation(fields: [riskEventId], references: [id], onDelete: Cascade)
  type        String    // SENSOR, PERMIT, MAINTENANCE, WORKER
  content     String    // Description of the evidence
  reference   String?   // Source identifier or file URL
}

model Alert {
  id               String    @id @default(uuid())
  zoneId           String
  zone             Zone      @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  sensorId         String?
  sensor           Sensor?   @relation(fields: [sensorId], references: [id], onDelete: SetNull)
  severity         String    // WARNING, CRITICAL
  message          String
  timestamp        DateTime  @default(now())
  acknowledged     Boolean   @default(false)
  acknowledgedBy   String?
  acknowledgedTime DateTime?
}

model Intervention {
  id                 String               @id @default(uuid())
  riskEventId        String
  riskEvent          RiskEvent            @relation(fields: [riskEventId], references: [id], onDelete: Cascade)
  title              String
  description        String
  priority           String               // LOW, MEDIUM, HIGH, CRITICAL
  estimatedReduction Float                // Percentage point reduction in risk score
  status             String               @default("RECOMMENDED") // RECOMMENDED, EXECUTING, COMPLETED, CANCELLED
  recommendedTime    DateTime             @default(now())
  executedTime       DateTime?
  executedBy         String?
  actions            InterventionAction[]
}

model InterventionAction {
  id             String       @id @default(uuid())
  interventionId String
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  actionText     String
  status         String       @default("PENDING") // PENDING, EXECUTED, FAILED
  sortOrder      Int          @default(0)
  executedTime   DateTime?
}

model Incident {
  id                String   @id @default(uuid())
  title             String
  description       String
  date              DateTime
  zoneId            String
  zone              Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  severity          String   // MINOR, MAJOR, CATASTROPHIC
  rootCause         String
  correctiveActions String
}

model NearMiss {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  zoneId      String
  zone        Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  reportedBy  String
  hazardType  String
}

model SafetyDocument {
  id         String          @id @default(uuid())
  title      String
  docType    String          // SOP, REGULATION, ACCIDENT_REPORT
  filePath   String
  content    String
  uploadedAt DateTime        @default(now())
  chunks     DocumentChunk[]
}

model DocumentChunk {
  id           String         @id @default(uuid())
  docId        String
  document     SafetyDocument @relation(fields: [docId], references: [id], onDelete: Cascade)
  chunkIndex   Int
  content      String
  metadataJson String         // Serialized metadata
}

model CopilotQuery {
  id           String   @id @default(uuid())
  queryText    String
  responseText String
  sourcesJson  String
  timestamp    DateTime @default(now())
  userId       String?
}

model SimulationRun {
  id           String            @id @default(uuid())
  scenarioName String
  status       String            @default("RUNNING") // RUNNING, PAUSED, COMPLETED, RESET
  startTime    DateTime          @default(now())
  endTime      DateTime?
  events       SimulationEvent[]
}

model SimulationEvent {
  id         String        @id @default(uuid())
  runId      String
  run        SimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  step       Int
  timestamp  DateTime      @default(now())
  eventType  String        // SENSOR_CHANGE, PERMIT_CONFLICT, RISK_ALERT, INTERVENTION_EXEC
  detailsJson String
}

model ModelVersion {
  id               String            @id @default(uuid())
  modelName        String
  version          String
  path             String
  trainedAt        DateTime          @default(now())
  metricsJson      String
  predictions      ModelPrediction[]
  evaluationRuns   EvaluationRun[]
}

model ModelPrediction {
  id           String       @id @default(uuid())
  modelId      String
  model        ModelVersion @relation(fields: [modelId], references: [id], onDelete: Cascade)
  featuresJson String
  prediction   Float        // Labeled risk prediction
  probability  Float        // Anomaly / incident probability
  timestamp    DateTime     @default(now())
}

model EvaluationRun {
  id                 String             @id @default(uuid())
  modelId            String
  model              ModelVersion       @relation(fields: [modelId], references: [id], onDelete: Cascade)
  timestamp          DateTime           @default(now())
  metricsJson        String
  confusionMatrixJson String
  metrics            EvaluationMetric[]
}

model EvaluationMetric {
  id          String        @id @default(uuid())
  evalRunId   String
  evalRun     EvaluationRun @relation(fields: [evalRunId], references: [id], onDelete: Cascade)
  metricName  String
  metricValue Float
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  resource  String
  details   String
  timestamp DateTime @default(now())
}
