# =========================================================================
# SAFEMESH AI - ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================

# Server Environment & Port Configuration
PORT=5000
NODE_ENV=production

# Database Connection (SQLite relative path or persistent volume path)
DATABASE_URL="file:./dev.db"

# Authentication Security Secret
JWT_SECRET="safemesh_ai_production_jwt_secret_key_2026_change_in_prod"

# Vision Intelligence - Roboflow Hosted Inference API (Optional / Auto-Fallback)
# Roboflow Model: industrialhazards/1
ROBOFLOW_API_KEY="your_roboflow_api_key_here"

# Python AI Service Configuration
PYTHON_EXEC="python"
AI_SERVICE_DIR="../ai-service"

# Frontend Application Binding (Optional CORS override)
VITE_API_BASE_URL=""
VITE_SOCKET_URL=""
